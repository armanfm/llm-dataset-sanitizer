[package]
name        = "terra_dourada"
version     = "2.0.0"
edition     = "2021"
description = "Terra Dourada Dataset Sanitizer v2 - features lexicais + FXL Turbo"

[[bin]]
name = "tds"
path = "src/main.rs"

[dependencies]
sha2       = "0.10"
serde      = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
rayon      = "1.8"
clap       = { version = "4.4", features = ["derive"] }

[profile.release]
opt-level     = 3
lto           = true
codegen-units = 1
strip         = true
